#!/bin/sh
# .githooks/pre-push — 编排：本地慢检查下沉处。
#   默认策略：测试 / 编译交 CI，本地 pre-push 无阻断，保证推送体验。
#   如需本地把关，往 stacks/<栈>/pre-push.d/ 放脚本即可（自动被拾取）。
here="$(dirname "$0")"
fail=0
ran=0

stack="$(sh "$here/lib/detect.sh")"
if [ -n "$stack" ]; then
  for c in "$here/stacks/$stack/pre-push.d/"*.sh; do
    [ -f "$c" ] && { ran=1; sh "$c" || fail=1; }
  done
fi

[ "$ran" = "0" ] && echo "ℹ️  [pre-push] 无本地慢检查（测试/编译交 CI）。" >&2
[ "$fail" != "0" ] && exit 1
exit 0

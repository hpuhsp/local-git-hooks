#!/bin/sh
# .githooks/prepare-commit-msg — 预置 AI 三档选项 + 读自动信号（规格 §4.1）
# 两段式取值：优先工具自动信号；读不到则在编辑器里预置三档供取消注释自报。
MSG_FILE="$1"

# (1) 优先读工具自动信号（支持的 AI 工具会设置这些环境变量）
AI_DEGREE="${QG_AI_DEGREE:-}"    # assisted | co-authored | generated

# (2) 工具没给信号 → 预置三档选项（默认 none）。已存在则不重复追加（amend/二次编辑）。
if [ -z "$AI_DEGREE" ]; then
  if ! grep -qE '^#? *QG-AI:' "$MSG_FILE" 2>/dev/null; then
    cat >> "$MSG_FILE" <<'TPL'

# ── AI 参与度（取消注释你选的一项，默认 none）──────────
# QG-AI: assisted      # AI 轻度协助（约 ≤33%）
# QG-AI: co-authored   # AI 实质贡献（约 35–67%）
# QG-AI: generated     # 主要由 AI 生成（67%+）
# ───────────────────────────────────────────────
TPL
  fi
fi

# 注：正式 trailer 统一在 commit-msg 阶段生成，避免重复 / 格式漂移。
exit 0

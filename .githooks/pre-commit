#!/bin/sh
# .githooks/pre-commit — 编排：通用门禁 + 栈叠加（core.hooksPath 原生分发）
#   慢检查一律下沉 pre-push / CI；此处只跑确定性、秒级的快检查。
#   试点：QG_WARN_ONLY=1 可让阻断级降级为告警。
here="$(dirname "$0")"
gitdir="$(git rev-parse --git-dir 2>/dev/null || echo .git)"

# merge / rebase 期间跳过，避免解决冲突时被反复打扰
if [ -f "$gitdir/MERGE_HEAD" ] || [ -d "$gitdir/rebase-merge" ] || [ -d "$gitdir/rebase-apply" ]; then
  exit 0
fi

fail=0
run() { sh "$here/common/$1.sh" || fail=1; }

# ── 通用层（先分支，再快检查）──
run protect-branch
run secret-scan
run no-conflict-markers
run no-large-files
run block-sensitive-files
run deps-consistency          # 告警级，qg_fail 不触发，fail 不受影响

# ── 格式化：原地修复后重新入库（仅限 format.sh 处理的 Java/Kotlin，避免带入无关的未暂存改动）──
sh "$here/common/format.sh"
git diff --cached --name-only --diff-filter=ACMR | grep -iE '\.(java|kts?)$' | while IFS= read -r f; do
  [ -f "$f" ] && git add -- "$f"
done

# ── 栈叠加层（按侦测结果，可为空）──
stack="$(sh "$here/lib/detect.sh")"
if [ -n "$stack" ]; then
  for c in "$here/stacks/$stack/pre-commit.d/"*.sh; do
    [ -f "$c" ] && { sh "$c" || fail=1; }
  done
fi

if [ "$fail" != "0" ]; then
  echo "" >&2
  echo "❌ pre-commit 未通过（上方有拦截项）。修复后重试，或 QG_WARN_ONLY=1 试点放行。" >&2
  exit 1
fi
exit 0
